PORT=4000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=phishing_triage

# Max upload size for .eml files (bytes)
MAX_UPLOAD_SIZE=10485760

# CORS: comma-separated list of allowed origins for the frontend (Phase 2+)
CORS_ORIGIN=http://localhost:5173

# --- Phase 2: AI layer (OpenAI-Compatible) ---
OPENAI_API_KEY=
# Comma-separated model rotation list, tried in order. Falls back to a
# built-in free-tier default list if left blank.
OPENAI_MODELS=meta-llama/llama-3.1-8b-instruct:free,google/gemma-2-9b-it:free
# Optional base URL for OpenAI-compatible APIs (defaults to OpenRouter)
OPENAI_BASE_URL=https://openrouter.ai/api/v1/chat/completions
# Sent as the HTTP-Referer header on AI requests
APP_URL=http://localhost:4000

# --- Phase 2: IOC enrichment (VirusTotal) ---
VIRUSTOTAL_API_KEY=

# --- Phase 2: IOC enrichment (urlscan.io) ---
URLSCAN_API_KEY=
