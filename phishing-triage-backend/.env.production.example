PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=<cpanel_db_user>
DB_PASSWORD=<cpanel_db_password>
DB_NAME=<cpanel_db_name>

MAX_UPLOAD_SIZE=10485760

# Set this to your production domain
CORS_ORIGIN=https://yourdomain.com

# --- Phase 2: AI layer (OpenRouter) ---
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODELS=meta-llama/llama-3.1-8b-instruct:free,google/gemma-2-9b-it:free,mistralai/mistral-7b-instruct:free,qwen/qwen-2-7b-instruct:free
APP_URL=https://yourdomain.com

# --- Phase 2: IOC enrichment (urlscan.io) ---
URLSCAN_API_KEY=
